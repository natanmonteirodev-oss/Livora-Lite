@using Livora_Lite_Blazor.Services
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<nav class="navbar navbar-expand-lg navbar-dark" style="background: linear-gradient(135deg, #1e5128 0%, #2d8659 100%); box-shadow: 0 2px 8px rgba(0,0,0,0.1);">
    <div class="container-fluid">
        <!-- Brand -->
        <a class="navbar-brand" href="/" style="font-weight: 700; font-size: 1.3rem;">
            <i class="fas fa-home me-2"></i>Livora Lite
        </a>

        <!-- Toggler for mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navigation Items -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto">
                @if (AuthService.IsAuthenticated())
                {
                    <!-- Dashboard -->
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">
                            <i class="fas fa-chart-line me-1"></i>Dashboard
                        </a>
                    </li>

                    <!-- Properties (if not Tenant) -->
                    @if (AuthService.GetCurrentUser()?.Role != "Tenant")
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/properties">
                                <i class="fas fa-building me-1"></i>Propriedades
                            </a>
                        </li>
                    }

                    <!-- Contracts -->
                    <li class="nav-item">
                        <a class="nav-link" href="/contracts">
                            <i class="fas fa-file-contract me-1"></i>Contratos
                        </a>
                    </li>

                    <!-- Payments -->
                    <li class="nav-item">
                        <a class="nav-link" href="/payments">
                            <i class="fas fa-money-bill me-1"></i>Pagamentos
                        </a>
                    </li>

                    <!-- User Profile Dropdown -->
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fas fa-user-circle me-1"></i>@(AuthService.GetCurrentUser()?.FirstName ?? "Usuário")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown" style="background: #fff;">
                            <li>
                                <a class="dropdown-item" href="/profile">
                                    <i class="fas fa-user me-2"></i>Meu Perfil
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" href="/settings">
                                    <i class="fas fa-cog me-2"></i>Configurações
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <button class="dropdown-item" @onclick="LogoutAsync">
                                    <i class="fas fa-sign-out-alt me-2"></i>Sair
                                </button>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <!-- Login and Register buttons when not authenticated -->
                    <li class="nav-item">
                        <a class="nav-link" href="/login">
                            <i class="fas fa-sign-in-alt me-1"></i>Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/register">
                            <i class="fas fa-user-plus me-1"></i>Registrar
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@code {
    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/", forceLoad: true);
    }
}
