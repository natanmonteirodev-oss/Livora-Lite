@model IEnumerable<Livora_Lite.Application.DTO.PaymentDTO>
@{
    ViewData["Title"] = "Pagamentos";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Pagamentos</li>
        </ol>
    </nav>
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="section-title">Gestão de Pagamentos</h1>
            <p class="text-muted">Controle de pagamentos recebidos</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg"><i class="fas fa-plus me-2"></i> Novo Pagamento</a>
    </div>

    <div class="mb-4">
        <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Pesquisar pagamentos...">
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th><i class="fas fa-file-invoice me-2"></i>Cobrança</th>
                        <th><i class="fas fa-calendar me-2"></i>Data</th>
                        <th><i class="fas fa-dollar-sign me-2"></i>Valor</th>
                        <th><i class="fas fa-credit-card me-2"></i>Método</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="paymentTable">
                    @foreach(var payment in Model ?? new List<Livora_Lite.Application.DTO.PaymentDTO>())
                    {
                        <tr>
                            <td>@payment.Billing?.Period</td>
                            <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                            <td><strong>R$ @payment.AmountPaid.ToString("F2")</strong></td>
                            <td>@payment.PaymentMethod?.Name</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@payment.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@payment.Id" class="btn btn-outline-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@payment.Id" class="btn btn-outline-danger"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (Model?.Any() != true)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">
                                <i class="fas fa-inbox text-muted" style="font-size: 2rem;"></i>
                                <p class="text-muted mt-2">Nenhum pagamento encontrado.</p>
                                <a asp-action="Create" class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus me-1"></i> Novo Pagamento
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light text-muted">
            <small>Total: <strong>@Model?.Count() ?? 0</strong></small>
        </div>
    </div>

    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#paymentTable tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
</div>

