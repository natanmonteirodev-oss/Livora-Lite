@model Livora_Lite.Application.DTO.UpdateUserRequestDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Editar Usuário - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Usuários", Url.Action("Index", "Users")),
        new BreadcrumbHelper.BreadcrumbItem("Editar Usuário", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Usuários</a></li>
            <li class="breadcrumb-item active">Editar Usuário</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">Editar Usuário</h1>
        <p class="text-muted">Atualize os dados do usuário no sistema</p>
    </div>

    <!-- Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <strong>Sucesso!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            <strong>Erro!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Form Card -->
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <form asp-action="Edit" method="post" class="form" novalidate>>
                @Html.AntiForgeryToken()
                <div class="card shadow-sm">
                    <!-- Hidden ID Field -->
                    <input asp-for="Id" type="hidden" />
                    <!-- Header -->
                    <div class="card-header bg-gradient">
                        <h5 class="mb-0">
                            <i class="fas fa-user me-2"></i> Dados do Usuário
                        </h5>
                    </div>

                    <!-- Body -->
                    <div class="card-body">
                        <div class="row">
                            <!-- Left Column -->
                            <div class="col-md-6">
                                <!-- Nome -->
                                <div class="form-group mb-3">
                                    <label asp-for="FirstName" class="form-label">
                                        <i class="fas fa-user me-2"></i> Nome
                                    </label>
                                    <input asp-for="FirstName" class="form-control form-control-lg" placeholder="Ex: João" />
                                    <span asp-validation-for="FirstName" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Email -->
                                <div class="form-group mb-3">
                                    <label asp-for="Email" class="form-label">
                                        <i class="fas fa-envelope me-2"></i> Email
                                    </label>
                                    <input asp-for="Email" class="form-control form-control-lg" type="email" placeholder="exemplo@email.com" />
                                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Status -->
                                <div class="form-group mb-3">
                                    <label asp-for="IsActive" class="form-label">
                                        <i class="fas fa-circle me-2"></i> Ativo
                                    </label>
                                    <div class="form-check form-switch">
                                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                        <label class="form-check-label" for="IsActive">
                                            Usuário ativo no sistema
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Right Column -->
                            <div class="col-md-6">
                                <!-- Sobrenome -->
                                <div class="form-group mb-3">
                                    <label asp-for="LastName" class="form-label">
                                        <i class="fas fa-user me-2"></i> Sobrenome
                                    </label>
                                    <input asp-for="LastName" class="form-control form-control-lg" placeholder="Ex: Da Silva" />
                                    <span asp-validation-for="LastName" class="text-danger small d-block mt-1"></span>
                                </div>

                                <!-- Role -->
                                <div class="form-group mb-3">
                                    <label asp-for="Role" class="form-label">
                                        <i class="fas fa-shield-alt me-2"></i> Papel
                                    </label>
                                    <select asp-for="Role" class="form-select form-select-lg">
                                        <option value="Home">Home</option>
                                        <option value="Admin">Admin</option>
                                        <option value="Manager">Manager</option>
                                    </select>
                                    <span asp-validation-for="Role" class="text-danger small d-block mt-1"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-light">
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-cancel">
                                <i class="fas fa-times me-2"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save me-2"></i> Atualizar Usuário
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


