@using Livora_Lite.Application.DTO
@{
    ViewData["Title"] = "Debug - Dashboard Data";
}

<div class="container-fluid mt-4">
    <h1>🔍 Debug Dashboard - Dados Carregados</h1>
    
    @if (Model != null)
    {
        <div class="alert alert-info">
            <strong>Tipo de Dashboard:</strong> 
            @if (Model is AdminDashboardDTO)
            {
                <span class="badge bg-primary">Admin Dashboard</span>
            }
            else if (Model is OwnerDashboardDTO)
            {
                <span class="badge bg-success">Owner Dashboard</span>
            }
            else
            {
                <span class="badge bg-warning">Tenant Dashboard</span>
            }
        </div>

        @if (Model is AdminDashboardDTO adminDashboard)
        {
            <div class="row">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Total de Usuários</h5>
                            <p class="card-text"><strong>@adminDashboard.TotalUsers</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Total de Propriedades</h5>
                            <p class="card-text"><strong>@adminDashboard.TotalProperties</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Total de Contratos</h5>
                            <p class="card-text"><strong>@adminDashboard.TotalContracts</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Contratos Ativos</h5>
                            <p class="card-text"><strong>@adminDashboard.TotalContracts_Active</strong></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Contratos Expirados</h5>
                            <p class="card-text"><strong>@adminDashboard.TotalContracts_Expired</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Receita Esperada</h5>
                            <p class="card-text"><strong>R$ @adminDashboard.TotalRevenueExpected.ToString("N2")</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Pagamentos Pendentes</h5>
                            <p class="card-text"><strong>@adminDashboard.PendingPayments</strong></p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">Valor Pendente</h5>
                            <p class="card-text"><strong>R$ @adminDashboard.PendingPaymentsAmount.ToString("N2")</strong></p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>Propriedades Top 5</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nome</th>
                                <th>Endereço</th>
                                <th>Status</th>
                                <th>Receita Mensal</th>
                                <th>Tenants Ativos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var prop in adminDashboard.TopProperties ?? new List<PropertySummaryDTO>())
                            {
                                <tr>
                                    <td>@prop.Id</td>
                                    <td>@prop.Name</td>
                                    <td>@prop.Address</td>
                                    <td><span class="badge bg-primary">@prop.Status</span></td>
                                    <td>R$ @prop.TotalMonthlyRevenue.ToString("N2")</td>
                                    <td>@prop.ActiveTenants</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5>Atividades Recentes (Últimas 10)</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped table-sm">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Ação</th>
                                <th>Entidade</th>
                                <th>Usuário</th>
                                <th>Data</th>
                                <th>Mudanças</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var activity in adminDashboard.RecentActivities ?? new List<RecentActivityDTO>())
                            {
                                <tr>
                                    <td>@activity.Id</td>
                                    <td>@activity.Action</td>
                                    <td>@activity.Entity</td>
                                    <td>@activity.UserName</td>
                                    <td>@activity.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@activity.Changes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-warning">
                Dados para outro tipo de dashboard (Owner ou Tenant)
            </div>
            <pre>@System.Text.Json.JsonSerializer.Serialize(Model, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
        }
    }
    else
    {
        <div class="alert alert-danger">
            Nenhum modelo encontrado!
        </div>
    }

    <div class="mt-4 mb-4">
        <a href="@Url.Action("Dashboard")" class="btn btn-primary">← Voltar ao Dashboard</a>
    </div>
</div>
