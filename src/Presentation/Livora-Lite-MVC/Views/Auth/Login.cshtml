@model Livora_Lite.Application.DTO.LoginRequestDTO

@{
    ViewData["Title"] = "Login - Livora";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>🌿 Livora</h1>
            <p>Bem-vindo de volta</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <div class="alert alert-danger">
                        @error.ErrorMessage
                    </div>
                }
            }
        }

        <form method="post" asp-action="Login">
            <div class="form-group">
                <label for="Email" class="form-label">Email</label>
                <input type="email" id="Email" name="Email" class="form-control" placeholder="seu@email.com" 
                    value="@Model?.Email" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Password" class="form-label">Senha</label>
                <input type="password" id="Password" name="Password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">Entrar</button>
        </form>

        <div class="auth-footer">
            <p>Não tem conta? <a asp-action="Register" asp-controller="Auth">Registre-se aqui</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
