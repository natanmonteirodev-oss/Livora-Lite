@model Livora_Lite.Application.DTO.AuditLogDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Detalhes do Log de Auditoria - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Logs de Auditoria", Url.Action("Index", "AuditLogs")),
        new BreadcrumbHelper.BreadcrumbItem("Detalhes", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Logs de Auditoria</a></li>
            <li class="breadcrumb-item active">Detalhes</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">Log de Auditoria #@Model.Id</h1>
        <p class="text-muted">Visualize os detalhes completos do log de auditoria</p>
    </div>

    <!-- Details Cards -->
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <!-- Audit Log Information Card -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-gradient">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i> Informações do Log
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Usuário:</strong> @Model.UserName <span class="text-muted small">(ID: @Model.UserId)</span></p>
                            <p><strong>Ação:</strong> <span class="badge bg-info">@Model.Action</span></p>
                            <p><strong>Entidade:</strong> @Model.Entity <span class="text-muted small">(ID: @Model.EntityId)</span></p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Data/Hora:</strong> @Model.Date.ToString("dd/MM/yyyy HH:mm:ss")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Changes Card -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-gradient">
                    <h5 class="mb-0">
                        <i class="fas fa-exchange-alt me-2"></i> Alterações
                    </h5>
                </div>
                <div class="card-body">
                    <pre class="p-3 bg-light rounded border">@Model.Changes</pre>
                </div>
            </div>

            <!-- Old Values Card -->
            @if (!string.IsNullOrEmpty(Model.OldValues))
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-gradient">
                        <h5 class="mb-0">
                            <i class="fas fa-trash-alt me-2"></i> Valores Antigos
                        </h5>
                    </div>
                    <div class="card-body">
                        <pre class="p-3 bg-light rounded border">@Model.OldValues</pre>
                    </div>
                </div>
            }

            <!-- New Values Card -->
            @if (!string.IsNullOrEmpty(Model.NewValues))
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-gradient">
                        <h5 class="mb-0">
                            <i class="fas fa-plus-circle me-2"></i> Novos Valores
                        </h5>
                    </div>
                    <div class="card-body">
                        <pre class="p-3 bg-light rounded border">@Model.NewValues</pre>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="card card-footer bg-light">
                <div class="d-flex gap-2">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-list me-2"></i> Voltar à Lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
