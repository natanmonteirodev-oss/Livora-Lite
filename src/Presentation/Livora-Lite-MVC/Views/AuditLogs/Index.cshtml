@model IEnumerable<Livora_Lite.Application.DTO.AuditLogDTO>
@{
    ViewData["Title"] = "Logs de Auditoria";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Logs de Auditoria</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h1 class="section-title">Logs de Auditoria</h1>
        <p class="text-muted">Histórico de ações realizadas no sistema</p>
    </div>

    <div class="mb-4">
        <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Pesquisar logs...">
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th><i class="fas fa-user me-2"></i>Usuário</th>
                        <th><i class="fas fa-bolt me-2"></i>Ação</th>
                        <th><i class="fas fa-cube me-2"></i>Entidade</th>
                        <th><i class="fas fa-clock me-2"></i>Data/Hora</th>
                        <th><i class="fas fa-file-alt me-2"></i>Detalhes</th>
                    </tr>
                </thead>
                <tbody id="auditTable">
                    @foreach(var log in Model ?? new List<Livora_Lite.Application.DTO.AuditLogDTO>())
                    {
                        <tr>
                            <td>@log.UserName</td>
                            <td><span class="badge bg-info">@log.Action</span></td>
                            <td>@log.Entity</td>
                            <td>@log.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><small>@log.Changes</small></td>
                        </tr>
                    }
                    @if (Model?.Any() != true)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">
                                <i class="fas fa-inbox text-muted" style="font-size: 2rem;"></i>
                                <p class="text-muted mt-2">Nenhum log de auditoria encontrado.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-light text-muted">
            <small>Total: <strong>@(Model?.Count() ?? 0)</strong> registros</small>
        </div>
    </div>

    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#auditTable tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
</div>

