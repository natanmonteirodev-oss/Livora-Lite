@model IEnumerable<Livora_Lite.Application.DTO.ContractDTO>
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Contratos - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Contratos", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Contratos</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="section-title">Gestão de Contratos</h1>
            <p class="text-muted">Gerencie todos os contratos de locação do seu portfólio</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i> Novo Contrato
        </a>
    </div>

    <!-- Search -->
    <div class="mb-4">
        <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Procurar contrato por propriedade, inquilino ou status...">
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th><i class="fas fa-home me-2"></i>Propriedade</th>
                        <th><i class="fas fa-user me-2"></i>Inquilino</th>
                        <th><i class="fas fa-calendar-check me-2"></i>Início</th>
                        <th><i class="fas fa-calendar-times me-2"></i>Fim</th>
                        <th><i class="fas fa-dollar-sign me-2"></i>Aluguel</th>
                        <th><i class="fas fa-circle me-2"></i>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="contractTable">
                    @if (Model?.Count() == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3" style="display: block;"></i>
                                <p class="text-muted mb-3">Nenhum contrato cadastrado ainda.</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus me-2"></i> Cadastrar Primeiro Contrato
                                </a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var contract in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@(contract.Property?.Name ?? "N/A")</strong>
                                </td>
                                <td>@(contract.Tenant != null ? $"{(contract.Tenant.FirstName ?? "")} {(contract.Tenant.LastName ?? "")}" : "N/A")</td>
                                <td>@contract.StartDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (contract.EndDate.HasValue)
                                    {
                                        @contract.EndDate.Value.ToString("dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Vigente</span>
                                    }
                                </td>
                                <td><strong>R$ @contract.RentValue.ToString("F2")</strong></td>
                                <td>
                                    <span class="badge bg-info">@contract.ContractStatus?.Name</span>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@contract.Id" class="btn btn-outline-info" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@contract.Id" class="btn btn-outline-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@contract.Id" class="btn btn-outline-danger" title="Deletar">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Footer -->
    <div class="mt-3 text-muted">
        <small>Total de contratos: <strong>@Model?.Count() ?? 0</strong></small>
    </div>
</div>

<script>
    document.getElementById('searchInput').addEventListener('keyup', function () {
        const filter = this.value.toLowerCase();
        const rows = document.querySelectorAll('#contractTable tr');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(filter) ? '' : 'none';
        });
    });
</script>

