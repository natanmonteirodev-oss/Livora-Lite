@model Livora_Lite.Application.DTO.MaintenanceRequestDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Excluir Solicitação de Manutenção - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Solicitações de Manutenção", Url.Action("Index", "MaintenanceRequests")),
        new BreadcrumbHelper.BreadcrumbItem("Excluir Solicitação", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Solicitações de Manutenção</a></li>
            <li class="breadcrumb-item active">Excluir Solicitação</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">Excluir Solicitação de Manutenção</h1>
        <p class="text-muted">Esta ação não pode ser desfeita. Tem certeza que deseja excluir esta solicitação?</p>
    </div>

    <!-- Form Card -->
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <form asp-action="DeleteConfirmed" method="post" class="form">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <div class="card shadow-sm border-danger">
                    <!-- Header -->
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i> Dados da Solicitação
                        </h5>
                    </div>

                    <!-- Body -->
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-briefcase me-2"></i> Título
                                    </label>
                                    <p class="form-control-plaintext">@Model.Title</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-building me-2"></i> Imóvel
                                    </label>
                                    <p class="form-control-plaintext">
                                        @if (Model?.Property != null)
                                        {
                                            @Model.Property.Name
                                        }
                                        else
                                        {
                                            <span>N/A</span>
                                        }
                                    </p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-calendar me-2"></i> Data da Solicitação
                                    </label>
                                    <p class="form-control-plaintext">@Model.RequestDate.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-arrow-up me-2"></i> Prioridade
                                    </label>
                                    <p class="form-control-plaintext">@Model.Priority</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-circle me-2"></i> Status
                                    </label>
                                    <p class="form-control-plaintext">@Model.Status</p>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-file-alt me-2"></i> Descrição
                                    </label>
                                    <p class="form-control-plaintext">@Model.Description</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="card-footer bg-light">
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="fas fa-trash me-2"></i> Excluir Solicitação
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .form-control-plaintext {
        padding-top: 0.5rem;
        padding-bottom: 0.5rem;
        padding-left: 0;
        color: var(--bs-body-color);
        font-weight: 500;
    }
</style>