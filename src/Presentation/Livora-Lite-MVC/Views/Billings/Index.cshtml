@model IEnumerable<Livora_Lite.Application.DTO.BillingDTO>
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Cobranças - Livora";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Cobranças</li>
        </ol>
    </nav>

    <!-- Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <strong>Sucesso!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            <strong>Erro!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="section-title">Gestão de Cobranças</h1>
            <p class="text-muted">Controle de cobranças e pagamentos</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i> Nova Cobrança
        </a>
    </div>

    <div class="mb-4">
        <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Pesquisar cobranças...">
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th><i class="fas fa-file-invoice me-2"></i>Contrato</th>
                        <th><i class="fas fa-calendar me-2"></i>Período</th>
                        <th><i class="fas fa-dollar-sign me-2"></i>Valor</th>
                        <th><i class="fas fa-calendar-times me-2"></i>Vencimento</th>
                        <th><i class="fas fa-circle me-2"></i>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="billingTable">
                    @if (Model?.Any() == true)
                    {
                        @foreach (var billing in Model)
                        {
                            <tr>
                                <td>@billing.Contract?.Property?.Name</td>
                                <td>@billing.Period</td>
                                <td><strong>R$ @billing.Amount.ToString("F2")</strong></td>
                                <td>@billing.DueDate.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-info">@billing.BillingStatus?.Name</span></td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Details" asp-route-id="@billing.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                        <a asp-action="Edit" asp-route-id="@billing.Id" class="btn btn-outline-warning"><i class="fas fa-edit"></i></a>
                                        <a asp-action="Delete" asp-route-id="@billing.Id" class="btn btn-outline-danger"><i class="fas fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    @if (Model?.Any() != true)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4">
                                <i class="fas fa-inbox text-muted" style="font-size: 2rem;"></i>
                                <p class="text-muted mt-2">Nenhuma cobrança encontrada.</p>
                                <a asp-action="Create" class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus me-1"></i> Criar Nova Cobrança
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-light text-muted">
            <small>Total: <strong>@(Model?.Count() ?? 0)</strong></small>
        </div>
    </div>

    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#billingTable tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
</div>

