@model IEnumerable<Livora_Lite.Application.DTO.ContractDTO>

@{
    ViewData["Title"] = "Contratos";
}

<h1>Gestão de Contratos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Novo Contrato</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Imóvel</th>
            <th>Inquilino</th>
            <th>Data Início</th>
            <th>Data Fim</th>
            <th>Valor Aluguel</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Property?.Name</td>
                <td>@item.Tenant?.Name</td>
                <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                <td>@(item.EndDate?.ToString("dd/MM/yyyy") ?? "Indeterminado")</td>
                <td>@item.RentValue.ToString("C")</td>
                <td>@item.ContractStatus?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>