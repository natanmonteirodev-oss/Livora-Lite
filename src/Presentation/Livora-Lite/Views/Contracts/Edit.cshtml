@model Livora_Lite.Application.DTO.UpdateContractRequestDTO

@{
    ViewData["Title"] = "Editar Contrato";
}

<h1>Editar Contrato</h1>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="PropertyId" class="control-label"></label>
                <select asp-for="PropertyId" class="form-control" asp-items="@(new SelectList(ViewBag.Properties, "Id", "Name"))"></select>
                <span asp-validation-for="PropertyId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TenantId" class="control-label"></label>
                <select asp-for="TenantId" class="form-control" asp-items="@(new SelectList(ViewBag.Tenants, "Id", "Name"))"></select>
                <span asp-validation-for="TenantId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="StartDate" class="control-label"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EndDate" class="control-label"></label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
                <small class="form-text text-muted">Deixe em branco para contrato indeterminado</small>
            </div>
            <div class="form-group">
                <label asp-for="RentValue" class="control-label"></label>
                <input asp-for="RentValue" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="RentValue" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DueDay" class="control-label"></label>
                <input asp-for="DueDay" class="form-control" type="number" min="1" max="31" />
                <span asp-validation-for="DueDay" class="text-danger"></span>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="LateFee" class="control-label"></label>
                <input asp-for="LateFee" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="LateFee" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="InterestRate" class="control-label"></label>
                <input asp-for="InterestRate" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="InterestRate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SecurityDeposit" class="control-label"></label>
                <input asp-for="SecurityDeposit" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="SecurityDeposit" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ContractStatusId" class="control-label"></label>
                <select asp-for="ContractStatusId" class="form-control" asp-items="@(new SelectList(ViewBag.ContractStatuses, "Id", "Name"))"></select>
                <span asp-validation-for="ContractStatusId" class="text-danger"></span>
            </div>
        </div>
    </div>
    <div class="form-group">
        <input type="submit" value="Salvar" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>