@model Livora_Lite.Application.DTO.ContractDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Excluir Contrato - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Contratos", Url.Action("Index", "Contracts")),
        new BreadcrumbHelper.BreadcrumbItem("Excluir Contrato", null, true)
    );
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Contratos</a></li>
            <li class="breadcrumb-item active">Excluir Contrato</li>
        </ol>
    </nav>

    <div class="mb-4">
        <h1 class="section-title">Excluir Contrato</h1>
        <p class="text-muted">Esta ação não pode ser desfeita. Tem certeza que deseja excluir este contrato?</p>
    </div>

    <div class="row">
        <div class="col-lg-10 mx-auto">
            <form asp-action="DeleteConfirmed" method="post" class="form">
                <input type="hidden" asp-for="Id" />
                <div class="card shadow-sm border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i> Dados do Contrato</h5>
                    </div>

                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Imóvel</label>
                                    <p class="form-control-plaintext">@Model.Property?.Name</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Inquilino</label>
                                    <p class="form-control-plaintext">@(Model.Tenant != null ? $"{Model.Tenant.FirstName} {Model.Tenant.LastName}" : "N/A")</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Data de Início</label>
                                    <p class="form-control-plaintext">@Model.StartDate.ToString("dd/MM/yyyy")</p>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Valor do Aluguel</label>
                                    <p class="form-control-plaintext">@Model.RentValue.ToString("C")</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Data de Término</label>
                                    <p class="form-control-plaintext">@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("dd/MM/yyyy") : "Indefinida")</p>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-bold">Status</label>
                                    <p class="form-control-plaintext">@Model.ContractStatus?.Name</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-light">
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i> Cancelar
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="fas fa-trash me-2"></i> Excluir Contrato
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>