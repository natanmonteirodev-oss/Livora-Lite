@model Livora_Lite.Application.DTO.LoginRequestDTO

@{
    ViewData["Title"] = "Login - Livora";
}

<style>
    .auth-container {
        min-height: calc(100vh - 280px);
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0081a7 0%, #00afb9 100%);
        padding: 40px 20px;
    }

    .auth-card {
        background: white;
        border-radius: 16px;
        padding: 50px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    }

    .auth-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .auth-header h1 {
        color: #0081a7;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .auth-header p {
        color: #666;
        font-size: 1rem;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        color: #0081a7;
        font-weight: 600;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .form-control:focus {
        outline: none;
        border-color: #00afb9;
        box-shadow: 0 0 0 3px rgba(0, 175, 185, 0.1);
    }

    .form-control.input-validation-error {
        border-color: #f07167;
    }

    .text-danger {
        color: #f07167;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #0081a7 0%, #00afb9 100%);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-top: 10px;
    }

    .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0, 129, 167, 0.3);
    }

    .auth-footer {
        text-align: center;
        margin-top: 30px;
        padding-top: 30px;
        border-top: 2px solid #f0f0f0;
    }

    .auth-footer p {
        color: #666;
        margin: 0;
    }

    .auth-footer a {
        color: #00afb9;
        text-decoration: none;
        font-weight: 600;
    }

    .auth-footer a:hover {
        text-decoration: underline;
    }

    .alert-danger {
        background-color: #fff5f5;
        border: 2px solid #f07167;
        color: #c74345;
        padding: 12px 16px;
        border-radius: 8px;
        margin-bottom: 20px;
    }
</style>

<div class="auth-container">
    <div class="auth-card">
        <div class="auth-header">
            <h1>🌿 Livora</h1>
            <p>Bem-vindo de volta</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            @foreach (var modelState in ViewData.ModelState.Values)
            {
                @foreach (var error in modelState.Errors)
                {
                    <div class="alert alert-danger">
                        @error.ErrorMessage
                    </div>
                }
            }
        }

        <form method="post" asp-action="Login">
            <div class="form-group">
                <label for="Email" class="form-label">Email</label>
                <input type="email" id="Email" name="Email" class="form-control" placeholder="seu@email.com" 
                    value="@Model?.Email" required />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label for="Password" class="form-label">Senha</label>
                <input type="password" id="Password" name="Password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-login">Entrar</button>
        </form>

        <div class="auth-footer">
            <p>Não tem conta? <a asp-action="Register" asp-controller="Auth">Registre-se aqui</a></p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
