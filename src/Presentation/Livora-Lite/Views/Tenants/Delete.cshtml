@model Livora_Lite.Application.DTO.TenantDTO

@{
    ViewData["Title"] = "Excluir Inquilino";
}

<h1>Excluir Inquilino</h1>

<h3>Tem certeza que deseja excluir este inquilino?</h3>
<div>
    <h4>Inquilino</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Documento</dt>
        <dd class="col-sm-10">@Model.Document</dd>

        <dt class="col-sm-2">Telefone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.TenantStatus?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>