@model Livora_Lite.Application.DTO.CreateTenantRequestDTO

@{
    ViewData["Title"] = "Novo Inquilino";
}

<h1>Novo Inquilino</h1>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Document" class="control-label"></label>
                <input asp-for="Document" class="form-control" placeholder="CPF ou CNPJ" />
                <span asp-validation-for="Document" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Phone" class="control-label"></label>
                <input asp-for="Phone" class="form-control" placeholder="(11) 99999-9999" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="CurrentAddress" class="control-label"></label>
                <textarea asp-for="CurrentAddress" class="form-control" rows="3" placeholder="Endereço atual do inquilino"></textarea>
                <span asp-validation-for="CurrentAddress" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TenantStatusId" class="control-label"></label>
                <select asp-for="TenantStatusId" class="form-control" asp-items="@(new SelectList(ViewBag.TenantStatuses, "Id", "Name"))"></select>
                <span asp-validation-for="TenantStatusId" class="text-danger"></span>
            </div>
        </div>
    </div>
    <div class="form-group">
        <input type="submit" value="Criar" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>