@model IEnumerable<Livora_Lite.Application.DTO.TenantDTO>

@{
    ViewData["Title"] = "Inquilinos";
}

<h1>Gestão de Inquilinos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Novo Inquilino</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Documento</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Document</td>
                <td>@item.Phone</td>
                <td>@item.Email</td>
                <td>@item.TenantStatus?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>