@model IEnumerable<Livora_Lite.Application.DTO.TenantDTO>
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Inquilinos - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Inquilinos", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Inquilinos</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title">Gestão de Inquilinos</h1>
            <p class="text-muted">Gerencie todos os inquilinos cadastrados no sistema</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i> Novo Inquilino
        </a>
    </div>

    <!-- Search Bar -->
    <div class="mb-4">
        <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Procurar inquilino por nome, email ou documento..." />
    </div>

    <!-- Tenants Table -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-user me-2"></i> Nome</th>
                        <th><i class="fas fa-id-card me-2"></i> Documento</th>
                        <th><i class="fas fa-phone me-2"></i> Telefone</th>
                        <th><i class="fas fa-envelope me-2"></i> Email</th>
                        <th><i class="fas fa-circle me-2"></i> Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="tenantTable">
                    @if (Model.Count() == 0)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="fas fa-inbox fa-3x text-muted mb-3" style="display: block;"></i>
                                <p class="text-muted mb-3">Nenhum inquilino cadastrado ainda.</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus me-2"></i> Cadastrar Primeiro Inquilino
                                </a>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Name</strong></td>
                                <td>@item.Document</td>
                                <td>@item.Phone</td>
                                <td>@item.Email</td>
                                <td>
                                    <span class="badge badge-status badge-status-@item.TenantStatus?.Name?.ToLower()">@item.TenantStatus?.Name</span>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info" title="Detalhes">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger" title="Excluir">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Footer -->
    <div class="mt-3 text-muted">
        <small>Total de inquilinos: <strong>@Model.Count()</strong></small>
    </div>
</div>

<script>
    document.getElementById('searchInput').addEventListener('keyup', function () {
        const filter = this.value.toLowerCase();
        const rows = document.querySelectorAll('#tenantTable tr');
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(filter) ? '' : 'none';
        });
    });
</script>

<style>
    .table-dark {
        background-color: var(--livora-primary) !important;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }
</style>