@model Livora_Lite.Application.DTO.TenantDTO

@{
    ViewData["Title"] = "Detalhes do Inquilino";
}

<h1>Detalhes do Inquilino</h1>

<div>
    <h4>Inquilino</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Documento</dt>
        <dd class="col-sm-10">@Model.Document</dd>

        <dt class="col-sm-2">Telefone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Endereço Atual</dt>
        <dd class="col-sm-10">@Model.CurrentAddress</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.TenantStatus?.Name</dd>

        <dt class="col-sm-2">Data de Criação</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</dd>

        @if (Model.UpdatedAt.HasValue)
        {
            <dt class="col-sm-2">Última Atualização</dt>
            <dd class="col-sm-10">@Model.UpdatedAt.Value.ToString("dd/MM/yyyy HH:mm")</dd>
        }
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Voltar</a>
</div>