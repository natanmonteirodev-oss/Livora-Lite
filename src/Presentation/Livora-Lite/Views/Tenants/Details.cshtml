@model Livora_Lite.Application.DTO.TenantDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Detalhes do Inquilino - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Inquilinos", Url.Action("Index", "Tenants")),
        new BreadcrumbHelper.BreadcrumbItem("Detalhes", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Inquilinos</a></li>
            <li class="breadcrumb-item active">Detalhes</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">@Model.Name</h1>
        <p class="text-muted">Visualize os detalhes completos do inquilino</p>
    </div>

    <!-- Details Card -->
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-gradient">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i> Informaçőes Pessoais
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Nome:</strong> @Model.Name</p>
                            <p><strong>CPF/CNPJ:</strong> @Model.Document</p>
                            <p><strong>Telefone:</strong> @Model.Phone</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Email:</strong> @Model.Email</p>
                            <p><strong>Status:</strong> <span class="badge badge-status badge-status-@Model.TenantStatus?.Name?.ToLower()">@Model.TenantStatus?.Name</span></p>
                        </div>
                    </div>
                    <hr />
                    <p><strong>Endereço Atual:</strong></p>
                    <p>@Model.CurrentAddress</p>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="card card-footer bg-light">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="fas fa-edit me-2"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i> Excluir
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-list me-2"></i> Voltar ŕ Lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        background: linear-gradient(135deg, var(--livora-primary) 0%, var(--livora-secondary) 100%);
        color: #ffffff;
    }

    .card-header h5 {
        color: #ffffff;
    }
</style>
