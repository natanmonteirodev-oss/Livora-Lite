@model Livora_Lite.Application.DTO.PropertyDTO

@{
    ViewData["Title"] = "Excluir Imóvel";
}

<h1>Excluir Imóvel</h1>

<h3>Tem certeza que deseja excluir este imóvel?</h3>
<div>
    <h4>Imóvel</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nome</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Tipo</dt>
        <dd class="col-sm-10">@Model.PropertyType?.Name</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.PropertyStatus?.Name</dd>

        <dt class="col-sm-2">Endereço</dt>
        <dd class="col-sm-10">@Model.Address?.Street, @Model.Address?.Number - @Model.Address?.City</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>