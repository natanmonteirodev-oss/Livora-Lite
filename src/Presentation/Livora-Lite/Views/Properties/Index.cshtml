@model IEnumerable<Livora_Lite.Application.DTO.PropertyDTO>

@{
    ViewData["Title"] = "Imóveis";
}

<h1>Gestão de Imóveis</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Novo Imóvel</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Nome</th>
            <th>Tipo</th>
            <th>Status</th>
            <th>Endereço</th>
            <th>Quartos</th>
            <th>Banheiros</th>
            <th>Valor Sugerido</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.PropertyType?.Name</td>
                <td>@item.PropertyStatus?.Name</td>
                <td>@(item.Address?.Street), @item.Address?.Number - @item.Address?.City</td>
                <td>@item.Bedrooms</td>
                <td>@item.Bathrooms</td>
                <td>@item.SuggestedRentValue.ToString("C")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>