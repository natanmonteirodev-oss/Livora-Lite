@model IEnumerable<Livora_Lite.Application.DTO.PropertyDTO>
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Imóveis - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData, 
        new BreadcrumbHelper.BreadcrumbItem("Imóveis", null, true)
    );
}

<div class="container mt-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Imóveis</li>
        </ol>
    </nav>

    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="section-title mb-2">Gestão de Imóveis</h1>
            <p class="text-muted">Visualize, crie e gerencie todos os seus imóveis</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg">
            <i class="fas fa-plus me-2"></i> Novo Imóvel
        </a>
    </div>

    <!-- Search/Filter Bar -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Buscar por nome, cidade ou endereço..." id="searchInput">
            </div>
        </div>
    </div>

    <!-- Table Section -->
    @if (Model.Any())
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th><i class="fas fa-home me-2"></i>Nome</th>
                                <th><i class="fas fa-tag me-2"></i>Tipo</th>
                                <th><i class="fas fa-circle me-2"></i>Status</th>
                                <th><i class="fas fa-map-marker-alt me-2"></i>Endereço</th>
                                <th><i class="fas fa-door-open me-2"></i>Quartos</th>
                                <th><i class="fas fa-bath me-2"></i>Banheiros</th>
                                <th><i class="fas fa-dollar-sign me-2"></i>Valor Sugerido</th>
                                <th style="width: 150px;"><i class="fas fa-cog me-2"></i>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="align-middle">
                                    <td>
                                        <strong>@item.Name</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@item.PropertyType?.Name</span>
                                    </td>
                                    <td>
                                        @{
                                            var statusClass = item.PropertyStatus?.Name == "Ativo" ? "badge-active" : 
                                                            item.PropertyStatus?.Name == "Inativo" ? "badge-inactive" : "badge-pending";
                                        }
                                        <span class="badge-status @statusClass">@item.PropertyStatus?.Name</span>
                                    </td>
                                    <td class="small">
                                        @if (item.Address != null)
                                        {
                                            <div>@item.Address.Street, @item.Address.Number</div>
                                            <div class="text-muted">@item.Address.City - @item.Address.State</div>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@item.Bedrooms</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@item.Bathrooms</span>
                                    </td>
                                    <td>
                                        <strong class="text-primary">@item.SuggestedRentValue.ToString("C")</strong>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Details" asp-route-id="@item.Id" 
                                               class="btn btn-outline-primary" title="Visualizar detalhes">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" 
                                               class="btn btn-outline-warning" title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" 
                                               class="btn btn-outline-danger" title="Excluir">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Footer Info -->
        <div class="mt-4 text-center text-muted">
            <p>Total de <strong>@Model.Count()</strong> imóvel(is) cadastrado(s)</p>
        </div>
    }
    else
    {
        <!-- Empty State -->
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <div style="font-size: 48px; color: var(--livora-primary); margin-bottom: 20px;">
                    <i class="fas fa-inbox"></i>
                </div>
                <h4 class="mb-3">Nenhum imóvel cadastrado</h4>
                <p class="text-muted mb-4">Comece criando seu primeiro imóvel para gerenciar aluguéis</p>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus me-2"></i> Criar Primeiro Imóvel
                </a>
            </div>
        </div>
    }
</div>

<script>
    // Simple search functionality
    document.getElementById('searchInput')?.addEventListener('keyup', function(e) {
        const searchTerm = e.target.value.toLowerCase();
        const table = document.querySelector('.table');
        const rows = table?.querySelectorAll('tbody tr');
        
        rows?.forEach(row => {
            const text = row.textContent.toLowerCase();
            row.style.display = text.includes(searchTerm) ? '' : 'none';
        });
    });
</script>
