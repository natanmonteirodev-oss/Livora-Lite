@model Livora_Lite.Application.DTO.PropertyDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Detalhes do Imóvel - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Imóveis", Url.Action("Index", "Properties")),
        new BreadcrumbHelper.BreadcrumbItem("Detalhes", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Imóveis</a></li>
            <li class="breadcrumb-item active">Detalhes</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">@Model.Name</h1>
        <p class="text-muted">Visualize os detalhes completos do imóvel</p>
    </div>

    <!-- Details Cards -->
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <!-- Property Information Card -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-gradient">
                    <h5 class="mb-0">
                        <i class="fas fa-home me-2"></i> Informações do Imóvel
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Nome:</strong> @Model.Name</p>
                            <p><strong>Tipo:</strong> <span class="badge badge-info">@Model.PropertyType?.Name</span></p>
                            <p><strong>Status:</strong> <span class="badge badge-status badge-status-@Model.PropertyStatus?.Name?.ToLower()">@Model.PropertyStatus?.Name</span></p>
                            <p><strong>Área:</strong> @Model.Area.ToString("F2") m²</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Quartos:</strong> @Model.Bedrooms</p>
                            <p><strong>Banheiros:</strong> @Model.Bathrooms</p>
                            <p><strong>Vagas de Garagem:</strong> @Model.ParkingSpaces</p>
                            <p><strong>Valor Sugerido de Aluguel:</strong> <span class="text-primary fw-bold">R$ @Model.SuggestedRentValue.ToString("F2")</span></p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr />
                        <p><strong>Descrição:</strong></p>
                        <p>@Model.Description</p>
                    }
                </div>
            </div>

            <!-- Address Card -->
            @if (Model.Address != null)
            {
                <div class="card shadow-sm mb-3">
                    <div class="card-header bg-gradient">
                        <h5 class="mb-0">
                            <i class="fas fa-map-marker-alt me-2"></i> Endereço
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <p><strong>Rua:</strong> @Model.Address.Street</p>
                                <p><strong>Número:</strong> @Model.Address.Number</p>
                                <p><strong>Complemento:</strong> @(string.IsNullOrEmpty(Model.Address.Complement) ? "-" : Model.Address.Complement)</p>
                                <p><strong>Bairro:</strong> @Model.Address.Neighborhood</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Cidade:</strong> @Model.Address.City</p>
                                <p><strong>Estado:</strong> @Model.Address.State</p>
                                <p><strong>CEP:</strong> @Model.Address.ZipCode</p>
                                <p><strong>País:</strong> @Model.Address.Country</p>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="card card-footer bg-light">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="fas fa-edit me-2"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i> Excluir
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-list me-2"></i> Voltar à Lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        background: linear-gradient(135deg, var(--livora-primary) 0%, var(--livora-secondary) 100%);
        color: #ffffff;
    }

    .card-header h5 {
        color: #ffffff;
    }
</style>