@model IEnumerable<Livora_Lite.Application.DTO.UserDTO>
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Usuários";
    BreadcrumbHelper.SetBreadcrumbs(ViewData, 
        new BreadcrumbHelper.BreadcrumbItem("Usuários", null, true)
    );
}

<div class="container py-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <a class="btn btn-primary mb-3" asp-action="Create">
        <i class="bi bi-plus-circle"></i> Novo Usuário
    </a>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Data de Criação</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-info">@user.Role</span>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>
                            <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@user.Id">
                                    Editar
                                </a>
                                <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@user.Id">
                                    Remover
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Nenhum usuário encontrado.
        </div>
    }
</div>

