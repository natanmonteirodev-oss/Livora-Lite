@model Livora_Lite.Application.DTO.UserDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Excluir Usuário - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Usuários", Url.Action("Index", "Users")),
        new BreadcrumbHelper.BreadcrumbItem("Excluir", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Usuários</a></li>
            <li class="breadcrumb-item active">Excluir</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">Excluir Usuário</h1>
        <p class="text-muted">Confirme a exclusão do usuário</p>
    </div>

    <!-- Confirmation Card -->
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <!-- Warning Alert -->
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Atenção!</strong> Esta ação é irreversível. O usuário será permanentemente removido do sistema.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>

            <!-- User Information Card -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-danger">
                    <h5 class="mb-0 text-white">
                        <i class="fas fa-user me-2"></i> @Model.FirstName @Model.LastName
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Nome Completo:</strong> @Model.FullName</p>
                            <p><strong>Email:</strong> @Model.Email</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Função:</strong> <span class="badge bg-primary">@Model.Role</span></p>
                            <p><strong>Status:</strong> 
                                @if (Model.IsActive)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Confirmation Form -->
            <form asp-action="DeleteConfirmed" asp-route-id="@Model.Id" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger btn-lg">
                        <i class="fas fa-trash me-2"></i> Sim, Excluir Permanentemente
                    </button>
                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                        <i class="fas fa-times me-2"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .card-header {
        background: linear-gradient(135deg, var(--livora-primary) 0%, var(--livora-secondary) 100%);
        color: #ffffff;
    }

    .card-header.bg-danger {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%) !important;
    }

    .card-header h5 {
        color: #ffffff;
    }
</style>
