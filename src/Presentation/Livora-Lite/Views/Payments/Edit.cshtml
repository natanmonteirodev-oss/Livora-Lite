@model Livora_Lite.Application.DTO.UpdatePaymentRequestDTO
@{
    ViewData["Title"] = "Editar Pagamento";
}

<div class="container mt-5 mb-5">
    <h1 class="section-title mb-4">Editar Pagamento</h1>
    <div class="row"><div class="col-lg-6"><form asp-action="Edit" method="post" class="card shadow-sm"><input asp-for="Id" type="hidden" /><div class="card-header bg-gradient"><h5>Dados do Pagamento</h5></div><div class="card-body">
        <div class="mb-3"><label asp-for="BillingId" class="form-label">Cobrança</label><select asp-for="BillingId" class="form-select form-select-lg" asp-items="@(new SelectList(ViewBag.Billings, "Id", "Period"))"></select></div>
        <div class="mb-3"><label asp-for="PaymentDate" class="form-label">Data</label><input asp-for="PaymentDate" type="date" class="form-control form-control-lg" /></div>
        <div class="mb-3"><label asp-for="AmountPaid" class="form-label">Valor</label><input asp-for="AmountPaid" type="number" class="form-control form-control-lg" step="0.01" /></div>
        <div class="mb-3"><label asp-for="PaymentMethodId" class="form-label">Método</label><select asp-for="PaymentMethodId" class="form-select form-select-lg" asp-items="@(new SelectList(ViewBag.PaymentMethods, "Id", "Name"))"></select></div>
    </div><div class="card-footer bg-light d-flex gap-2 justify-content-end"><a asp-action="Index" class="btn btn-secondary">Cancelar</a><button type="submit" class="btn btn-primary">Atualizar</button></div></form></div></div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }

