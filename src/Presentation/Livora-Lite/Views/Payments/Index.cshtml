@model IEnumerable<Livora_Lite.Application.DTO.PaymentDTO>
@{
    ViewData["Title"] = "Pagamentos";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Pagamentos</li>
        </ol>
    </nav>
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div><h1 class="section-title">Pagamentos</h1><p class="text-muted">Controle de pagamentos recebidos</p></div>
        <a asp-action="Create" class="btn btn-primary btn-lg"><i class="fas fa-plus me-2"></i> Novo</a>
    </div>
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-header">
                    <tr>
                        <th>Cobrança</th>
                        <th>Data</th>
                        <th>Valor</th>
                        <th>Método</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var payment in Model ?? new List<Livora_Lite.Application.DTO.PaymentDTO>())
                    {
                        <tr>
                            <td>@payment.Billing?.Period</td>
                            <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                            <td><strong>R$ @payment.AmountPaid.ToString("F2")</strong></td>
                            <td>@payment.PaymentMethod?.Name</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Edit" asp-route-id="@payment.Id" class="btn btn-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@payment.Id" class="btn btn-danger"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light text-muted">
            <small>Total: <strong>@Model?.Count() ?? 0</strong></small>
        </div>
    </div>
</div>

