@model IEnumerable<Livora_Lite.Application.DTO.PaymentDTO>

@{
    ViewData["Title"] = "Pagamentos";
}

<h1>Gestão de Pagamentos</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Novo Pagamento</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Cobrança</th>
            <th>Data do Pagamento</th>
            <th>Valor Pago</th>
            <th>Método de Pagamento</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Billing?.Contract?.Property?.Name - @item.Billing?.Period</td>
                <td>@item.PaymentDate.ToString("dd/MM/yyyy")</td>
                <td>@item.AmountPaid.ToString("C")</td>
                <td>@item.PaymentMethod?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>