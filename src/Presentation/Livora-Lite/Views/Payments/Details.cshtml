@model Livora_Lite.Application.DTO.PaymentDTO
@using Livora_Lite.Helpers

@{
    ViewData["Title"] = "Detalhes do Pagamento - Livora";
    BreadcrumbHelper.SetBreadcrumbs(ViewData,
        new BreadcrumbHelper.BreadcrumbItem("Pagamentos", Url.Action("Index", "Payments")),
        new BreadcrumbHelper.BreadcrumbItem("Detalhes", null, true)
    );
}

<div class="container mt-5 mb-5">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Pagamentos</a></li>
            <li class="breadcrumb-item active">Detalhes</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="mb-4">
        <h1 class="section-title">Pagamento #@Model.Id</h1>
        <p class="text-muted">Visualize os detalhes completos do pagamento</p>
    </div>

    <!-- Details Cards -->
    <div class="row">
        <div class="col-lg-10 mx-auto">
            <!-- Payment Information Card -->
            <div class="card shadow-sm mb-3">
                <div class="card-header bg-gradient">
                    <h5 class="mb-0">
                        <i class="fas fa-credit-card me-2"></i> Informações do Pagamento
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong>Cobrança:</strong> @Model.Billing?.Contract?.Property?.Name - @Model.Billing?.Period</p>
                            <p><strong>Data do Pagamento:</strong> @Model.PaymentDate.ToString("dd/MM/yyyy")</p>
                            <p><strong>Método de Pagamento:</strong> @Model.PaymentMethod?.Name</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>Valor Pago:</strong> <span class="text-primary fw-bold">@Model.AmountPaid.ToString("C")</span></p>
                            <p><strong>Data de Criação:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="card card-footer bg-light">
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="fas fa-edit me-2"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i> Excluir
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-list me-2"></i> Voltar à Lista
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card-header {
        background: linear-gradient(135deg, var(--livora-primary) 0%, var(--livora-secondary) 100%);
        color: #ffffff;
    }

    .card-header h5 {
        color: #ffffff;
    }
</style>