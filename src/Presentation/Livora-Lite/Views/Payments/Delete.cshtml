@model Livora_Lite.Application.DTO.PaymentDTO

@{
    ViewData["Title"] = "Excluir Pagamento";
}

<h1>Excluir Pagamento</h1>

<h3>Tem certeza que deseja excluir este pagamento?</h3>
<div>
    <h4>Pagamento</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Cobrança</dt>
        <dd class="col-sm-10">@Model.Billing?.Contract?.Property?.Name - @Model.Billing?.Period</dd>

        <dt class="col-sm-2">Data do Pagamento</dt>
        <dd class="col-sm-10">@Model.PaymentDate.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-2">Valor Pago</dt>
        <dd class="col-sm-10">@Model.AmountPaid.ToString("C")</dd>

        <dt class="col-sm-2">Método de Pagamento</dt>
        <dd class="col-sm-10">@Model.PaymentMethod?.Name</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Excluir" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </form>
</div>