@model IEnumerable<Livora_Lite.Application.DTO.BillingDTO>

@{
    ViewData["Title"] = "Cobranças";
}

<h1>Gestão de Cobranças</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nova Cobrança</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>Contrato</th>
            <th>Período</th>
            <th>Valor</th>
            <th>Data de Vencimento</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Contract?.Property?.Name - @item.Contract?.Tenant?.Name</td>
                <td>@item.Period</td>
                <td>@item.Amount.ToString("C")</td>
                <td>@item.DueDate.ToString("dd/MM/yyyy")</td>
                <td>@item.BillingStatus?.Name</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalhes</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                </td>
            </tr>
        }
    </tbody>
</table>