@model Livora_Lite.Application.DTO.CreateBillingRequestDTO

@{
    ViewData["Title"] = "Nova Cobrança";
}

<h1>Nova Cobrança</h1>

<form asp-action="Create" method="post">
    <div class="row">
        <div class="col-md-6">
            <div class="form-group">
                <label asp-for="ContractId" class="control-label">Contrato</label>
                <select asp-for="ContractId" class="form-control" asp-items="@(new SelectList(ViewBag.Contracts, "Id", "Property.Name", null, "Tenant.Name"))">
                    <option value="">Selecione um contrato</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Period" class="control-label">Período (MM/YYYY)</label>
                <input asp-for="Period" class="form-control" placeholder="Ex: 01/2024" />
                <span asp-validation-for="Period" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Amount" class="control-label">Valor</label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DueDate" class="control-label">Data de Vencimento</label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BillingStatusId" class="control-label">Status</label>
                <select asp-for="BillingStatusId" class="form-control" asp-items="@(new SelectList(ViewBag.BillingStatuses, "Id", "Name"))">
                    <option value="">Selecione um status</option>
                </select>
                <span asp-validation-for="BillingStatusId" class="text-danger"></span>
            </div>
        </div>
    </div>

    <div class="form-group">
        <input type="submit" value="Criar" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Voltar</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}