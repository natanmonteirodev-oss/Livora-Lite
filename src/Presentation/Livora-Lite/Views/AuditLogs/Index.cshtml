@model IEnumerable<Livora_Lite.Application.DTO.AuditLogDTO>
@{
    ViewData["Title"] = "Logs de Auditoria";
}

<div class="container mt-5 mb-5">
    <h1 class="section-title mb-4">Logs de Auditoria</h1>
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-header">
                    <tr>
                        <th>Usuário</th>
                        <th>Ação</th>
                        <th>Entidade</th>
                        <th>Data/Hora</th>
                        <th>Detalhes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var log in Model ?? new List<Livora_Lite.Application.DTO.AuditLogDTO>())
                    {
                        <tr>
                            <td>@log.UserName</td>
                            <td><span class="badge bg-info">@log.Action</span></td>
                            <td>@log.Entity</td>
                            <td>@log.Date.ToString("dd/MM/yyyy HH:mm")</td>
                            <td><small>@log.Changes</small></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light">
            <small>Total: <strong>@Model?.Count() ?? 0</strong> registros</small>
        </div>
    </div>
</div>

