@model IEnumerable<Livora_Lite.Application.DTO.MaintenanceRequestDTO>
@{
    ViewData["Title"] = "Manutenção";
}

<div class="container mt-5 mb-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index" asp-controller="Home">Dashboard</a></li>
            <li class="breadcrumb-item active">Manutenção</li>
        </ol>
    </nav>

    <!-- Messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <strong>Sucesso!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>
            <strong>Erro!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="section-title">Solicitações de Manutenção</h1>
            <p class="text-muted">Controle de manutenções e reparos</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg"><i class="fas fa-plus me-2"></i> Nova Solicitação</a>
    </div>

    <div class="mb-4">
        <input type="text" id="searchInput" class="form-control form-control-lg" placeholder="Pesquisar por título, propriedade...">
    </div>

    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th><i class="fas fa-wrench me-2"></i>Título</th>
                        <th><i class="fas fa-home me-2"></i>Propriedade</th>
                        <th><i class="fas fa-calendar me-2"></i>Data</th>
                        <th><i class="fas fa-exclamation-triangle me-2"></i>Prioridade</th>
                        <th><i class="fas fa-circle me-2"></i>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="maintenanceTable">
                    @foreach(var maintenance in Model ?? new List<Livora_Lite.Application.DTO.MaintenanceRequestDTO>())
                    {
                        <tr>
                            <td><strong>@maintenance.Title</strong></td>
                            <td>@maintenance.Property?.Name</td>
                            <td>@maintenance.RequestDate.ToString("dd/MM/yyyy")</td>
                            <td><span class="badge bg-warning">@maintenance.Priority</span></td>
                            <td><span class="badge bg-info">@maintenance.Status</span></td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a asp-action="Details" asp-route-id="@maintenance.Id" class="btn btn-outline-info"><i class="fas fa-eye"></i></a>
                                    <a asp-action="Edit" asp-route-id="@maintenance.Id" class="btn btn-outline-warning"><i class="fas fa-edit"></i></a>
                                    <a asp-action="Delete" asp-route-id="@maintenance.Id" class="btn btn-outline-danger"><i class="fas fa-trash"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (Model?.Any() != true)
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4">
                                <i class="fas fa-inbox text-muted" style="font-size: 2rem;"></i>
                                <p class="text-muted mt-2">Nenhuma solicitação de manutenção encontrada.</p>
                                <a asp-action="Create" class="btn btn-sm btn-primary">
                                    <i class="fas fa-plus me-1"></i> Criar Nova Solicitação
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="card-footer bg-light">
            <small>Total: <strong>@(Model?.Count() ?? 0)</strong></small>
        </div>
    </div>

    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#maintenanceTable tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });
    </script>
</div>

