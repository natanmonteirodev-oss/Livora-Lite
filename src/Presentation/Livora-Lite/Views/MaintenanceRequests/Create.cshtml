@model Livora_Lite.Application.DTO.CreateMaintenanceRequestDTO
@{
    ViewData["Title"] = "Nova Manutenção";
}

<div class="container mt-5 mb-5">
    <h1 class="section-title mb-4">Nova Solicitação de Manutenção</h1>
    <div class="row"><div class="col-lg-6"><form asp-action="Create" method="post" class="card shadow-sm"><div class="card-header bg-gradient"><h5>Detalhes</h5></div><div class="card-body">
        <div class="mb-3"><label asp-for="Title" class="form-label">Título</label><input asp-for="Title" class="form-control form-control-lg" placeholder="Descreva brevemente" /></div>
        <div class="mb-3"><label asp-for="PropertyId" class="form-label">Propriedade</label><select asp-for="PropertyId" class="form-select form-select-lg" asp-items="@ViewBag.PropertyId"></select></div>
        <div class="mb-3"><label asp-for="Description" class="form-label">Descrição</label><textarea asp-for="Description" class="form-control" rows="3"></textarea></div>
        <div class="mb-3"><label asp-for="Priority" class="form-label">Prioridade</label><select asp-for="Priority" class="form-select form-select-lg" asp-items="@ViewBag.Priority"></select></div>
        <div class="mb-3"><label asp-for="Status" class="form-label">Status</label><select asp-for="Status" class="form-select form-select-lg" asp-items="@ViewBag.Status"></select></div>
    </div><div class="card-footer bg-light d-flex gap-2 justify-content-end"><a asp-action="Index" class="btn btn-secondary">Cancelar</a><button type="submit" class="btn btn-primary">Criar</button></div></form></div></div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }

