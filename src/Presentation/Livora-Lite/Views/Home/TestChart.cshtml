@{
    ViewData["Title"] = "Test Chart";
}

<div class="container mt-5">
    <h1>Test Chart.js via CDN with Fallback</h1>
    
    <div style="position: relative; height: 300px; width: 100%; max-width: 500px; margin-bottom: 20px;">
        <canvas id="testChart"></canvas>
    </div>
    
    <div id="debugInfo" class="alert alert-info">
        <p><strong>Debug Information:</strong></p>
        <p id="chartStatus">Checking Chart.js...</p>
        <p id="chartVersion">Chart version: Checking...</p>
        <p id="chartType">Chart constructor exists: Checking...</p>
        <p id="canvasStatus">Canvas status: Checking...</p>
        <pre id="detailLog" style="background: #f5f5f5; padding: 10px; max-height: 300px; overflow-y: auto;"></pre>
    </div>
</div>

@section Scripts {
<script>
    let debugLog = [];
    
    function addDebugLog(message) {
        const timestamp = new Date().toLocaleTimeString();
        const logEntry = `[${timestamp}] ${message}`;
        debugLog.push(logEntry);
        console.log(logEntry);
        document.getElementById('detailLog').textContent = debugLog.join('\n');
    }
    
    addDebugLog('Script starting...');
    addDebugLog('typeof Chart = ' + typeof Chart);
    
    // Check before potential CDN load delay
    setTimeout(() => {
        addDebugLog('Check 1 (500ms): typeof Chart = ' + typeof Chart);
        addDebugLog('Check 1: window.Chart = ' + (typeof window.Chart !== 'undefined' ? 'defined' : 'undefined'));
    }, 500);
    
    // Check after potential load
    setTimeout(() => {
        addDebugLog('Check 2 (1500ms): typeof Chart = ' + typeof Chart);
        
        if (typeof Chart !== 'undefined') {
            addDebugLog('✅ Chart.js loaded successfully!');
            document.getElementById('chartStatus').innerHTML = '✅ Chart.js loaded successfully!';
            document.getElementById('chartVersion').innerHTML = 'Chart constructor available';
            document.getElementById('chartType').innerHTML = 'Chart constructor type: ' + typeof Chart;
            
            try {
                const canvas = document.getElementById('testChart');
                if (!canvas) {
                    addDebugLog('❌ Canvas element not found!');
                } else {
                    addDebugLog('✅ Canvas element found');
                    
                    const ctx = canvas.getContext('2d');
                    if (!ctx) {
                        addDebugLog('❌ Canvas context not available!');
                    } else {
                        addDebugLog('✅ Canvas context available');
                        
                        // Create test chart
                        const testChart = new Chart(ctx, {
                            type: 'bar',
                            data: {
                                labels: ['Test 1', 'Test 2', 'Test 3'],
                                datasets: [{
                                    label: 'Test Data',
                                    data: [10, 20, 30],
                                    backgroundColor: '#00afb9',
                                    borderColor: '#0081a7',
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    legend: { display: true }
                                },
                                scales: {
                                    y: {
                                        beginAtZero: true
                                    }
                                }
                            }
                        });
                        
                        addDebugLog('✅ Chart created successfully!');
                        document.getElementById('canvasStatus').innerHTML = '✅ Chart rendered';
                    }
                }
            } catch (err) {
                addDebugLog('❌ Error creating chart: ' + err.message);
                document.getElementById('canvasStatus').innerHTML = '❌ Error: ' + err.message;
            }
        } else {
            addDebugLog('❌ Chart.js NOT found!');
            document.getElementById('chartStatus').innerHTML = '❌ Chart.js NOT loaded - attempting fallback...';
            document.getElementById('chartType').innerHTML = 'Chart not available - trying fallback script';
        }
    }, 1500);
</script>
}
