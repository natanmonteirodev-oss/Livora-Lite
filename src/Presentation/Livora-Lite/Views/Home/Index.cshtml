@{
    ViewData["Title"] = "Inicio - Livora";
}

<!-- Start Hero Section -->
<div class="hero">
    <div class="container">
        <div class="row justify-content-between align-items-center">
            <div class="col-lg-5">
                <div class="intro-excerpt">
                    <h1>Gestão de Imóveis <span class="d-block">Simplificada</span></h1>
                    <p class="mb-4">
                        Simplifique a relação entre pessoas e imóveis. Clareza, controle e confiança 
                        para o aluguel de longa duração no Brasil.
                    </p>
                    <p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="@Url.Action("Dashboard", "Home")" class="btn btn-secondary me-2">Acessar Dashboard</a>
                        }
                        else
                        {
                            <a href="@Url.Action("Register", "Auth")" class="btn btn-secondary me-2">Começar Agora</a>
                            <a href="#pilares" class="btn btn-white-outline">Saiba Mais</a>
                        }
                    </p>
                </div>
            </div>
            <div class="col-lg-7">
                <div class="hero-img-wrap">
                    <img src="~/images/couch.png" class="img-fluid" alt="Livora Interface">
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End Hero Section -->

@if (!User.Identity?.IsAuthenticated == true)
{
    <!-- Start Purpose Section -->
    <div class="product-section">
        <div class="container">
            <div class="row">
                <div class="col-md-12 col-lg-3 mb-5 mb-lg-0">
                    <h2 class="mb-4 section-title">Por que escolher Livora?</h2>
                    <p class="mb-4">
                        A plataforma ideal para proprietários, gerenciadores e inquilinos. 
                        Gestão completa de imóveis em um único lugar.
                    </p>
                    <p><a href="@Url.Action("Register", "Auth")" class="btn btn-primary">Começar Grátis</a></p>
                </div>

                <div class="col-12 col-md-4 col-lg-3 mb-5 mb-md-0">
                    <a class="product-item" href="#">
                        <div class="bg-light-primary rounded p-4 mb-3" style="text-align: center;">
                            <i class="fas fa-home" style="font-size: 48px; color: var(--livora-primary);"></i>
                        </div>
                        <h3 class="product-title">Gerenciamento de Imóveis</h3>
                        <p>Cadastre e acompanhe todos os seus imóveis em um só lugar de forma organizada e eficiente.</p>
                    </a>
                </div>

                <div class="col-12 col-md-4 col-lg-3 mb-5 mb-md-0">
                    <a class="product-item" href="#">
                        <div class="bg-light-primary rounded p-4 mb-3" style="text-align: center;">
                            <i class="fas fa-file-contract" style="font-size: 48px; color: var(--livora-primary);"></i>
                        </div>
                        <h3 class="product-title">Contratos Digitais</h3>
                        <p>Crie, gerencie e acompanhe contratos de aluguel com segurança e transparência.</p>
                    </a>
                </div>

                <div class="col-12 col-md-4 col-lg-3 mb-5 mb-md-0">
                    <a class="product-item" href="#">
                        <div class="bg-light-primary rounded p-4 mb-3" style="text-align: center;">
                            <i class="fas fa-chart-bar" style="font-size: 48px; color: var(--livora-primary);"></i>
                        </div>
                        <h3 class="product-title">Relatórios Detalhados</h3>
                        <p>Acompanhe cobranças, pagamentos e tudo mais com relatórios em tempo real.</p>
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- End Purpose Section -->

    <!-- Start Why Choose Us Section -->
    <div class="why-choose-section">
        <div class="container">
            <div class="row justify-content-between">
                <div class="col-lg-6">
                    <h2 class="section-title">Características Principais</h2>
                    <p>Livora oferece ferramentas completas para gerenciamento profissional de imóveis e contratos.</p>

                    <div class="row my-5">
                        <div class="col-6 col-md-6">
                            <div class="feature">
                                <div class="icon">
                                    <i class="fas fa-lock" style="font-size: 32px; color: var(--livora-primary);"></i>
                                </div>
                                <h3>Segurança</h3>
                                <p>Seus dados estão seguros com criptografia e autenticação moderna.</p>
                            </div>
                        </div>

                        <div class="col-6 col-md-6">
                            <div class="feature">
                                <div class="icon">
                                    <i class="fas fa-mobile-alt" style="font-size: 32px; color: var(--livora-primary);"></i>
                                </div>
                                <h3>Acesso Mobile</h3>
                                <p>Gerencie seus imóveis de qualquer lugar, a qualquer hora.</p>
                            </div>
                        </div>

                        <div class="col-6 col-md-6">
                            <div class="feature">
                                <div class="icon">
                                    <i class="fas fa-headset" style="font-size: 32px; color: var(--livora-primary);"></i>
                                </div>
                                <h3>Suporte 24/7</h3>
                                <p>Estamos aqui para ajudar você sempre que precisar.</p>
                            </div>
                        </div>

                        <div class="col-6 col-md-6">
                            <div class="feature">
                                <div class="icon">
                                    <i class="fas fa-sync-alt" style="font-size: 32px; color: var(--livora-primary);"></i>
                                </div>
                                <h3>Sincronização</h3>
                                <p>Todos os dados sincronizados em tempo real.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="img-wrap">
                        <img src="~/images/why-choose-us-img.jpg" alt="Livora Características" class="img-fluid">
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- End Why Choose Us Section -->

    <!-- Start CTA Section -->
    <div class="we-help-section">
        <div class="container">
            <div class="row">
                <div class="col-lg-12 text-center">
                    <h2 class="section-title mb-4">Pronto para começar?</h2>
                    <p class="mb-5" style="font-size: 18px; max-width: 600px; margin-left: auto; margin-right: auto;">
                        Junte-se a centenas de proprietários e gerenciadores que confiam em Livora 
                        para simplificar sua gestão de imóveis.
                    </p>
                    <a href="@Url.Action("Register", "Auth")" class="btn btn-secondary btn-lg">
                        <i class="fas fa-arrow-right me-2"></i> Criar Conta Gratuita
                    </a>
                </div>
            </div>
        </div>
    </div>
    <!-- End CTA Section -->
}
