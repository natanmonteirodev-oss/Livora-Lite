@model Livora_Lite.Application.DTO.AdminDashboardDTO
@using Livora_Lite.Helpers
@{
    ViewData["Title"] = "Dashboard Administrativo";
    BreadcrumbHelper.SetBreadcrumbs(ViewData, 
        new BreadcrumbHelper.BreadcrumbItem("Dashboard", null, true)
    );
}

<div class="container-fluid mt-4">
    <div class="livora-form-header">
        <h1 class="livora-form-title mb-0">Dashboard Administrativo</h1>
        <p class="livora-form-subtitle">Visão geral de todas as propriedades, contratos e pagamentos</p>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="livora-dashboard-card primary-accent">
                <h6 class="livora-card-title">Total de Usuários</h6>
                <p class="livora-card-value">@Model.TotalUsers</p>
                <p class="livora-card-subtitle">Usuários cadastrados no sistema</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="livora-dashboard-card secondary-accent">
                <h6 class="livora-card-title">Propriedades</h6>
                <p class="livora-card-value">@Model.TotalProperties</p>
                <p class="livora-card-subtitle">Imóveis cadastrados</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="livora-dashboard-card dark-accent">
                <h6 class="livora-card-title">Contratos Ativos</h6>
                <p class="livora-card-value">@Model.TotalContracts_Active</p>
                <p class="livora-card-subtitle">Acordos em vigência</p>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="livora-dashboard-card primary-accent">
                <h6 class="livora-card-title">Pagamentos Pendentes</h6>
                <p class="livora-card-value">@Model.PendingPayments</p>
                <p class="livora-card-subtitle">Cobranças em atraso</p>
            </div>
        </div>
    </div>

    <!-- Revenue and Alert Cards -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="livora-form-card">
                <h5 style="color: var(--livora-primary-green);" class="mb-0">Receita Esperada</h5>
                <h3 class="livora-card-value mt-3">R$ @Model.TotalRevenueExpected.ToString("N2")</h3>
                <p class="livora-card-subtitle">Soma de todos os aluguéis ativos</p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="livora-form-card">
                <h5 style="color: #dc3545;" class="mb-0">Valores Pendentes</h5>
                <h3 style="color: #dc3545; font-size: 1.8rem; font-weight: 700;" class="mt-3">R$ @Model.PendingPaymentsAmount.ToString("N2")</h3>
                <p class="livora-card-subtitle">@Model.PendingPayments pagamentos em atraso</p>
            </div>
        </div>
    </div>

    <!-- Tabs for more details -->
    <div class="row">
        <div class="col-12">
            <div class="livora-form-container">
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item">
                        <a class="nav-link active" id="contracts-tab" data-bs-toggle="tab" href="#contracts" role="tab">
                            Contratos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="maintenance-tab" data-bs-toggle="tab" href="#maintenance" role="tab">
                            Manutenções Pendentes (@Model.PendingMaintenance)
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" id="activity-tab" data-bs-toggle="tab" href="#activity" role="tab">
                            Atividades Recentes
                        </a>
                    </li>
                </ul>

                <div class="tab-content pt-4">
                    <!-- Contracts Tab -->
                    <div class="tab-pane fade show active" id="contracts" role="tabpanel">
                        <div class="row">
                            <div class="col-md-4">
                                <div class="livora-form-card">
                                    <h6 class="livora-card-title">Total de Contratos</h6>
                                    <p class="livora-card-value">@Model.TotalContracts</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="livora-form-card">
                                    <h6 class="livora-card-title">Ativos</h6>
                                    <p style="color: var(--livora-primary-green);" class="livora-card-value">@Model.TotalContracts_Active</p>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="livora-form-card">
                                    <h6 class="livora-card-title">Expirados</h6>
                                    <p style="color: #dc3545;" class="livora-card-value">@Model.TotalContracts_Expired</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Maintenance Tab -->
                    <div class="tab-pane fade" id="maintenance" role="tabpanel">
                        <p class="text-muted">Existem <strong>@Model.PendingMaintenance</strong> solicitações de manutenção pendentes.</p>
                        <a href="@Url.Action("Index", "MaintenanceRequests")" class="btn btn-primary">
                            Ver Todas as Manutenções
                        </a>
                    </div>

                    <!-- Activity Tab -->
                    <div class="tab-pane fade" id="activity" role="tabpanel">
                        @if (Model.RecentActivities.Any())
                        {
                            <div class="timeline">
                                @foreach (var activity in Model.RecentActivities)
                                {
                                    <div class="timeline-item mb-3">
                                        <div class="timeline-marker">
                                            <i class="bi bi-circle-fill"></i>
                                        </div>
                                        <div class="timeline-content">
                                            <h6 class="mb-1">
                                                @activity.UserName - <strong>@activity.Action</strong>
                                            </h6>
                                            <p class="text-muted small mb-2">
                                                Entidade: @activity.Entity
                                            </p>
                                            <small class="text-muted">
                                                @activity.CreatedAt.ToString("dd/MM/yyyy HH:mm:ss")
                                            </small>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="text-muted">Nenhuma atividade recente.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Top Properties -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="livora-form-container">
                <h5 class="livora-form-title mb-4">Propriedades em Destaque</h5>
                <div class="table-responsive">
                    <table class="livora-table table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Propriedade</th>
                                <th>Endereço</th>
                                <th>Status</th>
                                <th>Inquilinos Ativos</th>
                                <th>Receita Mensal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.TopProperties.Any())
                            {
                                @foreach (var property in Model.TopProperties)
                                {
                                    <tr>
                                        <td><strong>@property.Name</strong></td>
                                        <td>@property.Address</td>
                                        <td>
                                            <span class="badge-primary" style="background-color: var(--livora-secondary-blue); padding: 0.35em 0.65em; border-radius: 0.25rem; color: white;">@property.Status</span>
                                        </td>
                                        <td>
                                            <span class="badge-secondary" style="background-color: var(--livora-dark-blue); padding: 0.35em 0.65em; border-radius: 0.25rem; color: white;">@property.ActiveTenants</span>
                                        </td>
                                        <td style="color: var(--livora-primary-green); font-weight: 700;">R$ @property.TotalMonthlyRevenue.ToString("N2")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted">Nenhuma propriedade cadastrada</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 30px;
    }

    .timeline-item {
        position: relative;
    }

    .timeline-marker {
        position: absolute;
        left: -30px;
        top: 0;
        color: var(--livora-secondary-blue);
    }

    .timeline-content {
        padding: 12px;
        background-color: var(--livora-light-gray);
        border-radius: 4px;
    }

    .nav-tabs .nav-link {
        color: var(--livora-text-light);
        border: none;
        border-bottom: 2px solid transparent;
    }

    .nav-tabs .nav-link:hover {
        border-bottom-color: var(--livora-secondary-blue);
        color: var(--livora-secondary-blue);
    }

    .nav-tabs .nav-link.active {
        border-bottom-color: var(--livora-primary-green);
        color: var(--livora-primary-green);
        background-color: transparent;
    }
</style>
